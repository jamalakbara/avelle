<div
  class="elegant-page color-{{ section.settings.color_scheme }}"
  style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    <div class="elegant-page-hero" style="text-align: {{ section.settings.text_alignment }}; margin-bottom: 4rem;">
      <h1
        class="elegant-page-hero__heading"
        style="margin: 0; font-family: var(--font-heading--family); font-weight: var(--font-heading--weight); font-style: var(--font-heading--style); font-size: clamp(3rem, 5vw, 5.5rem); letter-spacing: -0.02em; line-height: 1.1;"
      >
        {{ page.title | escape }}
      </h1>
    </div>

    <div
      class="elegant-page-content"
      style="max-width: 75ch; margin: 0 auto; font-family: var(--font-body--family); font-size: 1.125rem; line-height: 1.6; color: rgb(var(--color-foreground-rgb) / 0.9);"
    >
      {{ page.content }}
    </div>
  </div>
</div>

<style>
  .elegant-page-content h2,
  .elegant-page-content h3,
  .elegant-page-content h4 {
    font-family: var(--font-heading--family);
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    line-height: 1.2;
    font-weight: var(--font-heading--weight);
  }

  .elegant-page-content p {
    margin-bottom: 1.5rem;
  }

  .elegant-page-content ul,
  .elegant-page-content ol {
    margin-bottom: 2rem;
    padding-left: 2rem;
  }

  .elegant-page-content li {
    margin-bottom: 0.5rem;
  }

  .elegant-page-content a {
    color: currentColor;
    text-decoration: underline;
    text-underline-offset: 0.3em;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', (event) => {
    if (typeof gsap !== 'undefined') {
      gsap.fromTo('.elegant-page-hero', { y: 30, opacity: 0 }, { y: 0, opacity: 1, duration: 1.2, ease: 'power3.out' });

      gsap.fromTo(
        '.elegant-page-content',
        { y: 30, opacity: 0 },
        { y: 0, opacity: 1, duration: 1.2, ease: 'power3.out', delay: 0.2 }
      );
    }
  });
</script>

{% schema %}
{
  "name": "Elegant Page",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 80
    }
  ]
}
{% endschema %}
