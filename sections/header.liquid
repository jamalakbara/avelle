{% comment %}
  Header Redesign
  Based on references/header.html with Tailwind CSS converted to custom CSS.
{% endcomment %}

{% schema %}
{
  "name": "t:names.header",
  "class": "header-section",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },

    {
      "type": "select",
      "id": "sticky_header_type",
      "options": [
        { "value": "none", "label": "t:sections.header.settings.sticky_header_type.options__1.label" },
        { "value": "on-scroll-up", "label": "t:sections.header.settings.sticky_header_type.options__2.label" },
        { "value": "always", "label": "t:sections.header.settings.sticky_header_type.options__3.label" }
      ],
      "default": "always",
      "label": "t:sections.header.settings.sticky_header_type.label"
    },
    {
      "type": "header",
      "content": "Sticky Header Overrides"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_header_product",
      "default": false,
      "label": "Enable sticky header on product page"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_header_collection",
      "default": false,
      "label": "Enable sticky header on collection page"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_header_cart",
      "default": false,
      "label": "Enable sticky header on cart page"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_header_search",
      "default": false,
      "label": "Enable sticky header on search page"
    },
    {
      "type": "checkbox",
      "id": "enable_transparent_header",
      "default": true,
      "label": "t:sections.header.settings.enable_transparent_header.label"
    },
    {
      "type": "checkbox",
      "id": "enable_transparent_header_product",
      "default": false,
      "label": "Enable transparent header on product page"
    },
    {
      "type": "checkbox",
      "id": "enable_transparent_header_collection",
      "default": true,
      "label": "Enable transparent header on collection page"
    },
    {
      "type": "checkbox",
      "id": "enable_transparent_header_page",
      "default": false,
      "label": "Enable transparent header on pages"
    },
    {
      "type": "checkbox",
      "id": "enable_transparent_header_search",
      "default": false,
      "label": "Enable transparent header on search page"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Scrolled State Override"
    },
    {
      "type": "color",
      "id": "scrolled_bg_color",
      "label": "Scrolled Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "scrolled_text_color",
      "label": "Scrolled Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Currency Switcher"
    },
    {
      "type": "checkbox",
      "id": "enable_custom_currency_ui",
      "label": "Use custom currency switcher in header",
      "info": "Replaces Nova app floating widget with a header-integrated dropdown. Uncheck to revert to Nova's default widget.",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "_header-logo"
    },
    {
      "type": "_header-menu"
    }
  ]
}
{% endschema %}

{%- liquid
  assign sticky_header_type = section.settings.sticky_header_type

  # Disable sticky header on specific pages unless explicitly enabled
  if template.name == 'product' and section.settings.enable_sticky_header_product == false
    assign sticky_header_type = 'none'
  elsif template.name == 'collection' and section.settings.enable_sticky_header_collection == false
    assign sticky_header_type = 'none'
  elsif template.name == 'list-collections' and section.settings.enable_sticky_header_collection == false
    assign sticky_header_type = 'none'
  elsif template.name == 'cart' and section.settings.enable_sticky_header_cart == false
    assign sticky_header_type = 'none'
  elsif template.name == 'search' and section.settings.enable_sticky_header_search == false
    assign sticky_header_type = 'none'
  endif

  assign transparent_header = false
  if template.name == 'index' and section.settings.enable_transparent_header
    assign transparent_header = true
  elsif template.name == 'product' and section.settings.enable_transparent_header_product
    assign transparent_header = true
  elsif template.name == 'collection' and section.settings.enable_transparent_header_collection
    assign transparent_header = true
  elsif template.name == 'list-collections' and section.settings.enable_transparent_header_collection
    assign transparent_header = true
  elsif template.name == 'cart'
    assign transparent_header = true
  elsif template.name == 'page' and section.settings.enable_transparent_header_page
    assign transparent_header = true
  elsif template.name == 'search' and section.settings.enable_transparent_header_search
    assign transparent_header = true
  endif

  assign logo = settings.logo
  assign logo_height = settings.logo_height | default: 30
  assign logo_width = logo_height | times: logo.aspect_ratio | round
  assign logo_height_mobile = settings.logo_height_mobile | default: 20
  assign logo_width_mobile = logo_height_mobile | times: logo.aspect_ratio | round
-%}

{% style %}
  /* Custom Variables mapped from Reference Tailwind Config */
  .header-custom {
    --color-burgundy-100: #5d0f17;
    --color-off-white: #f2f0ed;
    --color-white: #ffffff;
    --color-dark-burgundy: #300000;
    --header-bg-color: var(--color-white);
    --header-text-color: #000000;

    --header-scrolled-bg: {{ section.settings.scrolled_bg_color }};
    --header-scrolled-text: {{ section.settings.scrolled_text_color }};

    --header-height: 70px;
    --header-padding: 15px; /* gap-xxs */
    --nav-btn-height: 35px;
    --nav-btn-min-width: 70px;
    --nav-btn-hover-width: 120px;

    --icon-stroke-width: 1.5px; /* Ensure icons are visible */
  }

  @media screen and (min-width: 768px) {
    .header-custom {
      --header-height: 80px; /* h-nav */
      --header-padding: 30px; /* px-md approx */
      --nav-btn-height: 40px;
    }
  }

  /* Sticky & Transparent Logic */
  .header-custom.header-wrapper {
    position: relative;
    z-index: 100;
    width: 100%;
    transition: transform 0.3s ease, background-color 0.3s ease, color 0.3s ease, top 0.3s ease;
    background-color: var(--header-bg-color);
    color: var(--header-text-color);
    will-change: transform; /* Hint for smoother animation */
  }

  .header-custom.header-wrapper[data-sticky-type='on-scroll-up'] {
    position: fixed;
    top: 0;
    width: 100%;
    /* Let JS handle the translateY via inline style */
  }

  .header-custom.header-wrapper[data-sticky-type='always'] {
    position: sticky;
    top: 0;
  }

  .header-custom.header-wrapper.is-transparent {
    position: absolute;
    /* Fallback to 0, dynamically populated by JS to calculate precise offset of siblings like announcement bar */
    top: var(--announcement-bar-height, 0px);
    left: 0;
    right: 0;
    background: transparent;
    color: var(--color-white);
    border-bottom: none;
    transform: none !important; /* Force prevent any negative translations from JS */
  }

  .header-custom.header-wrapper.is-scrolled {
    background-color: var(--header-scrolled-bg) !important;
    color: var(--header-scrolled-text) !important;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    /* Reduce height when scrolled */
    --header-height: 60px;
  }

  @media screen and (min-width: 768px) {
    .header-custom.header-wrapper.is-scrolled {
       --header-height: 65px;
    }
  }

  /* When transparent and on-scroll-up/always, we need absolute/fixed depending on scrolled state */
  /* OVERRIDES for sticky behavior */
  .header-custom.header-wrapper.is-scrolled[data-sticky-type='on-scroll-up'],
  .header-custom.header-wrapper.is-scrolled[data-sticky-type='always']  {
     position: fixed;
     top: 0 !important; /* Reset any top offsets when it becomes a sticky block */
  }

  .header-custom.header-wrapper.is-hidden {
     transform: translateY(-100%);
  }

  .header-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding: 0 var(--header-padding);
    height: var(--header-height);
    width: 100%;
    margin: 0 auto;
    max-width: var(--page-width, 1440px);
    transition: height 0.3s ease; /* Ensure smooth height transition */
  }

  /* Left: Menu Button */
  .header-left {
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 3;
  }

  /* Hide default details summary from header-drawer */
  .header-left header-drawer > details > summary {
    display: none !important;
  }

  .btn-header-pill {
    display: flex;
    align-items: center;
    justify-content: center; /* Center icon when text is hidden */
    height: var(--nav-btn-height);
    min-width: 44px; /* Sufficient for a circle/pill */
    padding: 0 4px; /* Reduced padding, text margin handles spacing */
    border-radius: 9999px;
    background-color: transparent;
    color: inherit;
    border: none;
    cursor: pointer;
    overflow: hidden;
    /* Remove fixed max-width on parent, animate children instead or allow auto growth */
    transition: all 0.3s ease;
    box-shadow: none;
    text-decoration: none;
  }

  /* Add padding when expanded to look nice */
  .btn-header-pill:hover {
    padding-right: 16px;
    padding-left: 12px;
  }

  /* Specific fix for anchor tags behaving as flex containers */
  a.btn-header-pill {
    box-sizing: border-box;
  }

  .btn-header-pill .icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px; /* Fixed width for icon container */
    height: 32px;
    flex-shrink: 0;
  }

  .btn-header-pill .icon-wrapper svg {
    width: 16px;
    height: 16px;
  }

  /* Inherit text color for icons */
  .btn-header-pill .icon-wrapper svg path,
  .btn-header-pill .icon-wrapper svg circle {
    stroke: currentColor !important;
  }

  .btn-header-pill .text {
    max-width: 0;
    opacity: 0;
    margin-left: 0;
    overflow: hidden;
    white-space: nowrap;
    transition: all 0.3s ease;
    font-size: 13px;
    font-family: 'Poppins', sans-serif; /* Added Poppins font */
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .btn-header-pill:hover .text {
    max-width: 100px; /* Arbitrary large number for text to fit */
    opacity: 1;
    margin-left: 4px;
  }

  @media screen and (max-width: 1023px) {
    .btn-header-pill:hover .text {
      max-width: 0;
      opacity: 0;
      margin-left: 0;
    }
  }

  /* Center: Logo */
  .header-center {
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1;
  }

  .header-logo-link {
    display: block;
    line-height: 1;
    color: inherit;
    text-decoration: none;
  }

  .header-logo-image {
    display: block;
    height: auto;
    object-fit: contain;
    width: {{ logo_width }}px;
    max-height: calc(var(--header-height) - 20px); /* Ensure logo shrinks if needed */
    filter: brightness(0) invert(1);
    transition: filter 0.3s ease, width 0.3s ease, max-height 0.3s ease;
  }

  .header-custom.header-wrapper:not(.is-transparent) .header-logo-image {
    filter: brightness(0);
  }

  .header-custom.header-wrapper.is-scrolled .header-logo-image {
    filter: brightness(0) !important;
  }

  @media screen and (max-width: 767px) {
    .header-logo-image {
      width: {{ logo_width_mobile }}px;
    }
  }

  .header-logo-text {
    text-transform: uppercase;
    font-size: 24px;
    font-weight: bold;
    letter-spacing: 0.05em;
    color: var(--color-white);
  }

  /* Right: Actions */
  .header-right {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 12px;
    z-index: 2;
  }

  /* Cart Bubble Position Fix for Pill Button */
  .action-cart {
    position: relative;
  }

  /* Cart Bubble */
  .cart-count-bubble {
    position: absolute;
    background-color: var(--color-button);
    color: var(--color-button-text);
    height: 1.5rem;
    width: 1.5rem;
    border-radius: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    font-size: 0.8rem;
    top: -5px;
    right: -10px;
    line-height: 1;
  }

  .action-cart {
    position: relative;
  }

  /* Mobile */
  @media screen and (max-width: 1023px) {
    .action-link span.visually-hidden-mobile {
      display: none;
    }
    .header-right {
      gap: 15px;
    }
    .action-account {
      display: none;
    }
    .action-favorite {
      display: none;
    }
  }

  /* Desktop Nav */
  .header-desktop-nav {
    display: none;
  }

  @media screen and (min-width: 1024px) {
    /* Hide hamburger on desktop */
    .header-left .btn-header-pill {
      display: none;
    }

    .header-desktop-nav {
      display: flex;
      align-items: center;
    }

    .header-desktop-nav > ul {
      display: flex;
      align-items: center;
      gap: 2px;
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .header-desktop-nav > ul > li {
      position: relative;
    }

    .header-desktop-nav > ul > li > a {
      display: flex;
      align-items: center;
      height: var(--nav-btn-height);
      padding: 0 9px;
      border-radius: 9999px;
      font-size: 12px;
      font-family: 'Poppins', sans-serif;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: inherit;
      text-decoration: none;
      white-space: nowrap;
      transition: background-color 0.2s ease;
    }

    .header-desktop-nav > ul > li > a:hover {
      background-color: rgba(0, 0, 0, 0.06);
    }

    .is-transparent .header-desktop-nav > ul > li > a:hover {
      background-color: rgba(255, 255, 255, 0.15);
    }

    /* Dropdown */
    .header-desktop-nav .nav-dropdown {
      display: none;
      position: absolute;
      top: calc(100% + 4px);
      left: 0;
      min-width: 160px;
      background-color: #fff;
      border: 1px solid rgba(0, 0, 0, 0.08);
      border-radius: 8px;
      padding: 6px 0;
      list-style: none;
      margin: 0;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      z-index: 200;
    }

    .header-desktop-nav .has-dropdown:hover .nav-dropdown {
      display: block;
    }

    .header-desktop-nav .nav-dropdown li a {
      display: block;
      padding: 8px 16px;
      font-size: 13px;
      font-family: 'Poppins', sans-serif;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #000;
      text-decoration: none;
      white-space: nowrap;
      transition: background-color 0.15s ease;
    }

    .header-desktop-nav .nav-dropdown li a:hover {
      background-color: rgba(0, 0, 0, 0.04);
    }
  }

  /* WhatsApp floating button — move to right side */
  /* TODO: inspect live site for exact selector, then apply:
     [app-selector] { left: auto !important; right: 20px !important; }
  */

  @media screen and (max-width: 1023px) {
    .header-currency {
      display: none;
    }
  }

  /* Custom currency UI */
  .header-currency {
    position: relative;
  }

  .action-currency {
    gap: 4px;
  }

  .action-currency .currency-code {
    font-size: 13px;
    font-family: 'Poppins', sans-serif;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .action-currency .currency-caret {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 4px solid currentColor;
    flex-shrink: 0;
    margin-left: 2px;
  }

  .currency-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 200px;
    background-color: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 8px;
    padding: 6px 0;
    list-style: none;
    margin: 0;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    z-index: 300;
    color: #333;
  }

  .currency-dropdown.open {
    display: block;
  }

  .currency-dropdown li {
    padding: 8px 16px;
    font-size: 13px;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: background-color 0.15s ease;
  }

  .currency-dropdown li:hover {
    background-color: rgba(0, 0, 0, 0.04);
  }

  .currency-dropdown li.is-active {
    font-weight: 700;
  }
{% endstyle %}

{%- if section.settings.enable_custom_currency_ui -%}
  <style>
    .bacurr-cur-blocker { display: none !important; }
  </style>
{%- endif -%}

<header
  class="header-custom header-wrapper {% if transparent_header %}is-transparent{% endif %}"
  data-sticky-type="{{ sticky_header_type }}"
  data-template-name="{{ template.name }}"
  id="site-header"
>
  <div class="header-inner">
    <!-- LEFT -->
    <div class="header-left">
      {%- if section.settings.menu != blank -%}
        {% render 'header-drawer', linklist: section.settings.menu %}

        <button
          class="btn-header-pill group"
          onclick="const s = this.parentNode.querySelector('summary'); if(s) s.click()"
          aria-label="Menu"
        >
          <span class="icon-wrapper">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 3.5H13" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M1 10.5H13" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </span>
          <span class="text">Menu</span>
        </button>

        <nav class="header-desktop-nav" aria-label="Main navigation">
          <ul>
            {%- for link in section.settings.menu.links -%}
              <li class="{% if link.links != blank %}has-dropdown{% endif %}">
                <a href="{{ link.url }}">{{ link.title | escape }}</a>
                {%- if link.links != blank -%}
                  <ul class="nav-dropdown">
                    {%- for child_link in link.links -%}
                      <li><a href="{{ child_link.url }}">{{ child_link.title | escape }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </nav>
      {%- endif -%}
    </div>

    <!-- CENTER -->
    <div class="header-center">
      <a href="{{ routes.root_url }}" class="header-logo-link">
        {%- if logo != blank -%}
          {%- assign image_size_2x = logo_width | times: 2 | at_most: 5760 -%}
          <img
            srcset="{{ logo | image_url: width: logo_width }} 1x, {{ logo | image_url: width: image_size_2x }} 2x"
            src="{{ logo | image_url: width: logo_width }}"
            loading="eager"
            width="{{ logo_width }}"
            height="{{ logo_height }}"
            alt="{{ logo.alt | default: shop.name | escape }}"
            class="header-logo-image"
          >
        {%- else -%}
          <span class="h2 header-logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <!-- RIGHT -->
    <div class="header-right">
      {%- if section.settings.enable_custom_currency_ui -%}
        <div class="header-currency" id="header-currency-switcher">
          <button class="btn-header-pill action-currency" aria-label="Currency" aria-haspopup="listbox" aria-expanded="false">
            <span class="currency-code">IDR</span>
            <span class="currency-caret" aria-hidden="true"></span>
          </button>
          <ul class="currency-dropdown" role="listbox" aria-label="Select currency">
            <!-- Populated by JS from Nova's #baCurrSelector -->
          </ul>
        </div>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="btn-header-pill action-account"
        >
          <span class="icon-wrapper">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 7C8.65685 7 10 5.65685 10 4C10 2.34315 8.65685 1 7 1C5.34315 1 4 2.34315 4 4C4 5.65685 5.34315 7 7 7Z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M13 13C13 10.2386 10.3137 8 7 8C3.68629 8 1 10.2386 1 13" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span class="text">Sign In</span>
        </a>
      {%- endif -%}

      <button
        class="btn-header-pill action-search"
        onclick="const sm = document.getElementById('search-modal'); if(sm) sm.showDialog()"
        aria-label="{{ 'content.search' | t }}"
      >
        <span class="icon-wrapper">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="6" cy="6" r="4.5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M12.5 12.5L9.5 9.5" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="text">Search</span>
      </button>

      <button class="btn-header-pill action-favorite" aria-label="Favorites">
        <span class="icon-wrapper">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M7 12C7 12 1 8.5 1 4.5C1 2.567 2.567 1 4.5 1C5.59 1 6.56 1.48 7 2.25C7.44 1.48 8.41 1 9.5 1C11.433 1 13 2.567 13 4.5C13 8.5 7 12 7 12Z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <span class="text">Favorites</span>
      </button>

      {%- if settings.cart_type == 'drawer' and template.name != 'cart' -%}
        <script src="{{ 'cart-drawer.js' | asset_url }}" type="module" fetchpriority="low"></script>

        {% capture empty_cart_drawer_content %}
          <div class="cart-drawer__header">
            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button close-button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <div
            class="cart-drawer__content"
            aria-label="{{ 'content.cart_title' | t }}"
          >
            <h2 class="cart-drawer__heading h4 cart-drawer__heading--empty">
              {{ 'content.your_cart_is_empty' | t }}
            </h2>

            <div class="cart-drawer__items">
              {% render 'cart-products', force_empty: true %}
            </div>
          </div>
        {% endcapture %}

        <cart-drawer-component
          class="cart-drawer"
          {% if settings.auto_open_cart_drawer %}
            auto-open
          {% endif %}
        >
          <template id="empty-cart-template">
            {{ empty_cart_drawer_content }}
          </template>

          <button
            class="btn-header-pill action-cart"
            id="cart-icon-bubble"
            on:click="/open"
            aria-haspopup="dialog"
            aria-label="{{ 'content.cart_title' | t }}"
          >
            <span class="icon-wrapper">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1H2.5L3.9 8.02C3.96 8.32 4.09 8.59 4.29 8.81C4.49 9.03 4.75 9.17 5.05 9.22H11.55C11.85 9.17 12.11 9.03 12.31 8.81C12.51 8.59 12.64 8.32 12.7 8.02L13.5 4H3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="5" cy="12" r="1" stroke-width="1.5"/>
                <circle cx="11" cy="12" r="1" stroke-width="1.5"/>
              </svg>
            </span>
            <span class="text">{{ cart.item_count }} Items</span>
            {%- if cart != empty and cart.item_count > 0 -%}
              <div class="cart-count-bubble">
                <span aria-hidden="true">{{ cart.item_count }}</span>
              </div>
            {%- endif -%}
          </button>

          <dialog
            ref="dialog"
            class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{%endif%}"
            aria-labelledby="cart-drawer-heading"
            scroll-lock
            cart-summary-sticky="true"
          >
            <div class="cart-drawer__inner" data-hydration-key="cart-drawer-inner">
              <cart-items-component class="cart-items-component" data-drawer data-section-id="{{ section.id }}">
                {%- if cart.empty? -%}
                  {{ empty_cart_drawer_content }}
                {%- else -%}
                  <div class="cart-drawer__header" id="cart-drawer-header">
                    <h2 class="cart-drawer__heading h4" id="cart-drawer-heading">
                      {{ 'content.cart_title' | t }}
                    </h2>
                    <button
                      ref="closeButton"
                      on:click="cart-drawer-component/close"
                      class="button close-button cart-drawer__close-button button-unstyled"
                      aria-label="{{ 'actions.close' | t }}"
                    >
                      <span class="svg-wrapper">
                        {{- 'icon-close.svg' | inline_asset_content -}}
                      </span>
                    </button>
                  </div>

                  <scroll-hint
                    class="cart-drawer__content"
                    aria-label="{{ 'content.cart_title' | t }}"
                    style="--header-height: 60px;"
                  >
                    <div class="cart-drawer__items">
                      {% render 'cart-products' %}
                    </div>
                    <div class="cart-drawer__summary">
                      {% render 'cart-summary', section_id: section.id %}
                    </div>
                  </scroll-hint>
                {%- endif -%}
              </cart-items-component>
            </div>
          </dialog>
        </cart-drawer-component>
      {%- else -%}
        <a href="{{ routes.cart_url }}" class="btn-header-pill action-cart" id="cart-icon-bubble">
          <span class="icon-wrapper">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 1H2.5L3.9 8.02C3.96 8.32 4.09 8.59 4.29 8.81C4.49 9.03 4.75 9.17 5.05 9.22H11.55C11.85 9.17 12.11 9.03 12.31 8.81C12.51 8.59 12.64 8.32 12.7 8.02L13.5 4H3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="5" cy="12" r="1" stroke-width="1.5"/>
              <circle cx="11" cy="12" r="1" stroke-width="1.5"/>
            </svg>
          </span>
          <span class="text">{{ cart.item_count }} Items</span>
          {%- if cart != empty and cart.item_count > 0 -%}
            <div class="cart-count-bubble">
              <span aria-hidden="true">{{ cart.item_count }}</span>
            </div>
          {%- endif -%}
        </a>
      {%- endif -%}
    </div>
  </div>
</header>
<script>
  (() => {
    const header = document.getElementById('site-header');
    if (!header) return;

    // Dynamically calculate the offset needed for transparent heading
    const setHeaderOffset = () => {
        const headerGroup = document.getElementById('header-group');
        if (headerGroup) {
            let offsetHeight = 0;
            const headerSection = header.closest('.shopify-section') || header;
            for (let child of headerGroup.children) {
                if (child === headerSection) break;
                offsetHeight += child.offsetHeight;
            }
            document.documentElement.style.setProperty('--announcement-bar-height', `${offsetHeight}px`);
        }
    };
    setHeaderOffset();
    window.addEventListener('resize', setHeaderOffset);

    // Sticky header logic
    const stickyType = header.dataset.stickyType;
    let lastScrollY = window.scrollY;
    let ticking = false;

    // Check initial transparency state
    const isInitiallyTransparent = {{ transparent_header | json }};

    const updateHeader = () => {
        const currentScrollY = window.scrollY;

        // Add solid background if scrolled more than 50px
        if (currentScrollY > 50) {
            header.classList.add('is-scrolled');
        } else {
            header.classList.remove('is-scrolled');
        }

        const isScrollingDown = currentScrollY > lastScrollY;
        const scrollDifference = Math.abs(currentScrollY - lastScrollY);

        // Sticky Logic - Hide/Show on scroll via class instead of inline transform
        // This is much safer and respects CSS specificity like !important rules
        if (stickyType === 'on-scroll-up') {
             if (isScrollingDown && currentScrollY > 150 && scrollDifference > 5) {
                 header.classList.add('is-hidden');
             } else if (!isScrollingDown && scrollDifference > 5) {
                 header.classList.remove('is-hidden');
             }
        } else if (stickyType === 'always') {
             header.classList.remove('is-hidden');
        }

        lastScrollY = currentScrollY;
        ticking = false;
    };

    // Run once on load to ensure initial state is correct
    updateHeader();

    const handleScroll = () => {
        if (!ticking) {
            window.requestAnimationFrame(updateHeader);
            ticking = true;
        }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    // Run once on load
    updateHeader();
  })();
</script>

{%- if section.settings.enable_custom_currency_ui -%}
<script>
  (() => {
    function initCurrencySwitcher(switcher, { floating }) {
      if (!switcher) return null;

      const btn = switcher.querySelector(floating ? '.action-currency' : '.drawer-currency-toggle');
      const label = switcher.querySelector(floating ? '.currency-code' : '.drawer-currency-label');
      const dropdown = switcher.querySelector(floating ? '.currency-dropdown' : '.drawer-currency-list');
      const caret = floating ? null : switcher.querySelector('.icon-caret--forward');

      function syncAll(value) {
        switcher.querySelectorAll('li').forEach(el => el.classList.toggle('is-active', el.dataset.currency === value));
        if (label) label.textContent = value;
      }

      function triggerNova(value, select) {
        const novaItem = document.querySelector(`.bacurr-dropdown-choices .currMovers[id="${value}"]`);
        if (novaItem) {
          novaItem.click();
        } else {
          select.value = value;
          select.dispatchEvent(new Event('change', { bubbles: true }));
        }
      }

      function buildList(select) {
        dropdown.innerHTML = '';
        if (floating) dropdown.removeAttribute('hidden');
        Array.from(select.options).forEach(opt => {
          const li = document.createElement('li');
          li.textContent = opt.text;
          li.dataset.currency = opt.value;
          li.setAttribute('role', 'option');
          if (opt.selected) {
            if (label) label.textContent = opt.value;
            li.classList.add('is-active');
          }
          li.addEventListener('click', () => {
            triggerNova(opt.value, select);
            syncAll(opt.value);
            if (floating) closeDropdown();
          });
          dropdown.appendChild(li);
        });
      }

      function openDropdown() {
        if (floating) {
          dropdown.classList.add('open');
        } else {
          dropdown.removeAttribute('hidden');
          if (caret) caret.style.transform = 'rotate(90deg)';
        }
        btn.setAttribute('aria-expanded', 'true');
      }

      function closeDropdown() {
        if (floating) {
          dropdown.classList.remove('open');
        } else {
          dropdown.setAttribute('hidden', '');
          if (caret) caret.style.transform = '';
        }
        btn.setAttribute('aria-expanded', 'false');
      }

      btn.addEventListener('click', e => {
        e.stopPropagation();
        btn.getAttribute('aria-expanded') === 'true' ? closeDropdown() : openDropdown();
      });

      if (floating) {
        document.addEventListener('click', closeDropdown);
        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDropdown(); });
      }

      return { buildList, syncAll };
    }

    const headerSwitcher = initCurrencySwitcher(
      document.getElementById('header-currency-switcher'), { floating: true }
    );
    const drawerSwitcher = initCurrencySwitcher(
      document.getElementById('drawer-currency-switcher'), { floating: false }
    );

    function waitForNova(attempts) {
      const select = document.getElementById('baCurrSelector');
      if (select) {
        if (headerSwitcher) headerSwitcher.buildList(select);
        if (drawerSwitcher) drawerSwitcher.buildList(select);
        select.addEventListener('change', () => {
          if (headerSwitcher) headerSwitcher.syncAll(select.value);
          if (drawerSwitcher) drawerSwitcher.syncAll(select.value);
        });
        return;
      }
      if (attempts > 0) setTimeout(() => waitForNova(attempts - 1), 400);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => waitForNova(20));
    } else {
      waitForNova(20);
    }
  })();
</script>
{%- endif -%}
