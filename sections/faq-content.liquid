<div
  class="section faq-content page-width color-{{ section.settings.color_scheme }}"
  style="padding-block-start: {{ section.settings['padding-block-start'] }}px; padding-block-end: {{ section.settings['padding-block-end'] }}px;"
>
  <template id="faq-source-{{ section.id }}">{{ page.content }}</template>
  <template id="faq-icons-{{ section.id }}">
    <span class="svg-wrapper icon-plus">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
    <span class="svg-wrapper icon-minus">{{- 'icon-minus.svg' | inline_asset_content -}}</span>
  </template>
  <div id="faq-output-{{ section.id }}"></div>
  <noscript>{{ page.content }}</noscript>
</div>

<script>
(function () {
  const id = '{{ section.id }}';
  const sourceEl = document.getElementById('faq-source-' + id);
  const iconsEl = document.getElementById('faq-icons-' + id);
  const output = document.getElementById('faq-output-' + id);
  if (!sourceEl || !output) return;

  const parser = new DOMParser();
  const doc = parser.parseFromString(sourceEl.innerHTML, 'text/html');
  const nodes = [...doc.body.children];

  const fragment = document.createDocumentFragment();
  let currentItems = null;
  let currentContent = null;
  let hasStructure = false;

  for (const node of nodes) {
    const tag = node.tagName.toLowerCase();
    const isHeading = /^h[1-6]$/.test(tag);
    const boldEls = [...node.querySelectorAll('strong, b')];
    const boldText = boldEls.map(el => el.textContent).join('').trim();
    const isQuestion = tag === 'p' && boldText.length > 0 && boldText === node.textContent.trim();

    if (isHeading) {
      hasStructure = true;

      const group = document.createElement('div');
      group.className = 'faq-group';

      const h = document.createElement('h3');
      h.className = 'faq-group__heading';
      h.textContent = node.textContent;

      currentItems = document.createElement('div');
      currentItems.className = 'accordion accordion--plus accordion--dividers';

      group.appendChild(h);
      group.appendChild(currentItems);
      fragment.appendChild(group);
      currentContent = null;

    } else if (isQuestion && currentItems) {
      const wrap = document.createElement('accordion-custom');
      const details = document.createElement('details');
      details.className = 'details';

      const summary = document.createElement('summary');
      summary.className = 'details__header';
      summary.textContent = node.textContent.trim();
      if (iconsEl) summary.appendChild(iconsEl.content.cloneNode(true));

      currentContent = document.createElement('div');
      currentContent.className = 'details-content';

      details.appendChild(summary);
      details.appendChild(currentContent);
      wrap.appendChild(details);
      currentItems.appendChild(wrap);

    } else if (currentContent) {
      currentContent.appendChild(node.cloneNode(true));
    }
  }

  if (hasStructure) {
    output.appendChild(fragment);
  } else {
    output.innerHTML = sourceEl.innerHTML;
  }
})();
</script>

{% stylesheet %}
  .faq-content {
    --faq-group-gap: 3.5rem;
  }

  .faq-group + .faq-group {
    padding-block-start: var(--faq-group-gap);
  }

  .faq-group__heading {
    font-family: var(--font-heading--family);
    font-size: var(--font-h3--size);
    font-weight: var(--font-h3--weight);
    line-height: var(--font-h3--line-height);
    margin-block-end: 1.25rem;
  }

  .faq-content .accordion {
    width: 100%;
  }

  .faq-content .accordion--dividers accordion-custom .details {
    border-color: rgba(var(--color-foreground), 0.1);
    padding-bottom: 2px;
  }

  .faq-content .accordion--dividers accordion-custom:not(:first-child) .details {
    border-block-start: 1px solid rgba(var(--color-foreground), 0.1);
  }

  .faq-content .accordion--dividers accordion-custom:first-child .details {
    border-block-start: 1px solid rgba(var(--color-foreground), 0.1);
  }

  .faq-content .accordion--dividers accordion-custom:last-child .details {
    border-block-end: 1px solid rgba(var(--color-foreground), 0.1);
  }

  .faq-content .accordion--dividers .details-content {
    padding-block-end: 0.75rem;
    overflow: visible;
  }

  /* Plus/minus icon toggle */
  .faq-content .accordion--plus .icon-caret {
    display: none;
  }

  .faq-content .accordion--plus .icon-minus {
    display: none;
  }

  .faq-content .accordion--plus accordion-custom details[open] .icon-plus {
    display: none;
  }

  .faq-content .accordion--plus accordion-custom details[open] .icon-minus {
    display: block;
  }

  .faq-content .details__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    min-height: var(--minimum-touch-target, 44px);
    cursor: pointer;
    list-style: none;
    width: 100%;
  }

  .faq-content .details__header::-webkit-details-marker {
    display: none;
  }

  .faq-content .svg-wrapper {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
  }

  .faq-content .details-content p {
    font-family: var(--font-secondary--family, var(--font-body--family));
    font-size: 1rem;
    line-height: 1.6;
    font-weight: 300;
  }

  .faq-content .details-content * {
    font-weight: 300;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ Content",
  "tag": null,
  "class": "section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ]
}
{% endschema %}
