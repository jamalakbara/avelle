{%- style -%}
  .section-shoppable-video-gallery {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .ugc-gallery__heading {
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-align: left;
    margin: 0 0 32px;
  }

  /* ── Grid ── */
  .ugc-gallery__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
  }

  @media screen and (min-width: 750px) {
    .ugc-gallery__grid {
      grid-template-columns: repeat(var(--columns, 4), 1fr);
    }
  }

  /* ── Cards ── */
  .ugc-card {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    cursor: pointer;
    outline: none;
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.65s cubic-bezier(0.16, 1, 0.3, 1) var(--card-delay, 0s),
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1) var(--card-delay, 0s);
  }

  .ugc-card.is-visible {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .ugc-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  .ugc-card__media {
    position: absolute;
    inset: 0;
  }

  .ugc-card__thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition:
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1),
      filter 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .ugc-card:hover .ugc-card__thumbnail {
      transform: scale(1.04);
      filter: brightness(0.88);
    }
  }

  .ugc-card__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, transparent 45%);
  }

  /* ── Play button ── */
  .ugc-card__play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 52px;
    height: 52px;
    background: rgba(255, 255, 255, 0.92);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111;
    pointer-events: none;
    animation: ugc-pulse 2.4s ease-out infinite;
    transition: transform 0.25s ease, background 0.2s ease;
  }

  @keyframes ugc-pulse {
    0%   { box-shadow: 0 0 0 0   rgba(255, 255, 255, 0.55); }
    70%  { box-shadow: 0 0 0 18px rgba(255, 255, 255, 0); }
    100% { box-shadow: 0 0 0 0   rgba(255, 255, 255, 0); }
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .ugc-card:hover .ugc-card__play-btn {
      transform: translate(-50%, -50%) scale(1.1);
      background: #fff;
    }
  }

  /* ── Creator handle ── */
  .ugc-card__handle {
    position: absolute;
    bottom: 12px;
    left: 12px;
    font-size: 0.75rem;
    color: #fff;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(8px) saturate(1.5);
    -webkit-backdrop-filter: blur(8px) saturate(1.5);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    padding: 4px 10px;
    letter-spacing: 0.01em;
  }

  /* ── Modal ── */
  .ugc-modal {
    padding: 0;
    border: none;
    border-radius: 16px;
    overflow: hidden;
    max-width: min(90vw, 960px);
    height: min(90dvh, 700px);
    width: 100%;
  }

  .ugc-modal::backdrop {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(24px) brightness(0.25);
    -webkit-backdrop-filter: blur(24px) brightness(0.25);
  }

  .ugc-modal[open] {
    animation: ugc-modal-in 0.32s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  @keyframes ugc-modal-in {
    from { opacity: 0; transform: scale(0.95); }
    to   { opacity: 1; transform: scale(1); }
  }

  .ugc-modal.dialog-closing {
    animation: ugc-modal-out 0.22s ease forwards;
  }

  @keyframes ugc-modal-out {
    from { opacity: 1; transform: scale(1); }
    to   { opacity: 0; transform: scale(0.95); }
  }

  .ugc-modal__close {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 10;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.32);
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: background 0.2s;
  }

  .ugc-modal__close:hover {
    background: rgba(255, 255, 255, 0.28);
  }

  .ugc-modal__inner {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
  }

  .ugc-modal__video-pane {
    background: #000;
    overflow: hidden;
    position: relative;
  }

  .ugc-modal__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ugc-modal__product-pane {
    min-height: 0;
    display: flex;
    flex-direction: column;
    padding: 32px 24px 24px;
    background: #FAFAF8;
    color: var(--color-foreground, #111);
    overflow: hidden;
    border-left: 1px solid rgba(0, 0, 0, 0.06);
  }

  .ugc-modal__heading {
    font-family: var(--font-body--family, system-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin: 0 0 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    opacity: 0.55;
  }

  .ugc-modal__products {
    flex: 1;
    overflow-y: scroll;
    overscroll-behavior: contain;
    display: flex;
    flex-direction: column;
    gap: 4px;
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 0, 0, 0.15) transparent;
  }

  /* ── Product items ── */
  .ugc-product-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    transition: opacity 0.2s;
  }

  .ugc-product-item:last-child {
    border-bottom: none;
  }

  @media (hover: hover) {
    .ugc-product-item:hover {
      opacity: 0.75;
    }
  }

  .ugc-product-item__img-wrap {
    flex-shrink: 0;
  }

  .ugc-product-item__image {
    width: 92px;
    height: 92px;
    object-fit: cover;
    border-radius: 6px;
    display: block;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (hover: hover) {
    .ugc-product-item:hover .ugc-product-item__image {
      transform: scale(1.04);
    }
  }

  .ugc-product-item__info {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
    flex: 1;
  }

  .ugc-product-item__name {
    font-size: 0.875rem;
    font-weight: 500;
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ugc-product-item__price {
    font-size: 0.8125rem;
    margin: 0;
    opacity: 0.72;
  }

  /* ── Variant select ── */
  .ugc-variant-select {
    font-size: 0.72rem;
    padding: 5px 12px;
    border: 1px solid rgba(0, 0, 0, 0.18);
    border-radius: 999px;
    background: transparent;
    color: inherit;
    cursor: pointer;
    max-width: 100%;
    letter-spacing: 0.02em;
  }

  /* ── Add to cart button ── */
  .ugc-atc-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 6px;
    padding: 0.65rem 1.6rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    background: transparent;
    color: var(--color-foreground, #111);
    border: 1.5px solid var(--color-foreground, #111);
    border-radius: 999px;
    cursor: pointer;
    align-self: flex-start;
    white-space: nowrap;
    transition: background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .ugc-atc-btn:hover:not(:disabled) {
    background-color: var(--color-foreground, #111);
    color: var(--color-background, #fff);
    transform: translateY(-2px);
  }

  .ugc-atc-btn:active:not(:disabled) {
    transform: scale(0.97);
  }

  .ugc-atc-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ugc-atc-btn.ugc-atc-btn--added {
    background: transparent;
    color: #2a7f3e;
    border-color: #2a7f3e;
  }

  .ugc-atc-btn.ugc-atc-btn--error {
    background: transparent;
    color: #c0392b;
    border-color: #c0392b;
  }

  /* ── Mobile: full-screen stacked ── */
  @media screen and (max-width: 749px) {
    .ugc-modal {
      max-width: 100dvw;
      width: 100dvw;
      height: 100dvh;
      border-radius: 0;
    }

    .ugc-modal__inner {
      grid-template-columns: 1fr;
      grid-template-rows: 52% 48%;
    }

    .ugc-modal__close {
      color: #111;
      background: rgba(255, 255, 255, 0.8);
      border-color: rgba(0, 0, 0, 0.15);
    }
  }

  /* ── Hide custom cursor while modal open ── */
  body.ugc-modal-open .custom-cursor,
  body.ugc-modal-open .cursor-follower {
    display: none !important;
  }

  /* ── View transition hero ── */
  ::view-transition-group(ugc-hero) {
    animation-duration: 0.35s;
    animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
  }
{%- endstyle -%}

<shoppable-video-gallery-component>

  {%- comment -%} Pre-rendered product panels (hidden); JS swaps into modal on card click {%- endcomment -%}
  {%- for block in section.blocks -%}
    <div class="ugc-products-panel" data-panel-id="{{ block.id }}" hidden aria-hidden="true">
      {%- for product in block.settings.product_list -%}
        {%- assign first_variant = product.selected_or_first_available_variant -%}
        <div class="ugc-product-item">
          <div class="ugc-product-item__img-wrap">
            {%- if product.featured_image -%}
              {{
                product.featured_image
                | image_url: width: 200
                | image_tag: class: 'ugc-product-item__image', loading: 'lazy'
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'ugc-product-item__image placeholder' }}
            {%- endif -%}
          </div>
          <div class="ugc-product-item__info">
            <p class="ugc-product-item__name">{{ product.title }}</p>
            <p class="ugc-product-item__price">{{ product.price | money }}</p>
            {%- if product.variants.size > 1 -%}
              <select class="ugc-variant-select" aria-label="{{ 'accessibility.variant_for' | t: product_title: product.title | default: product.title }}">
                {%- for variant in product.variants -%}
                  <option
                    value="{{ variant.id }}"
                    {%- unless variant.available %} disabled{%- endunless -%}
                  >
                    {{- variant.title -}}
                    {%- unless variant.available %} – {{ 'products.product.sold_out' | t | default: 'Sold out' }}{%- endunless -%}
                  </option>
                {%- endfor -%}
              </select>
            {%- endif -%}
            <button
              class="ugc-atc-btn"
              data-variant-id="{{ first_variant.id }}"
              {%- unless first_variant.available %} disabled aria-disabled="true"{%- endunless -%}
            >
              {%- if first_variant.available -%}
                {{ 'products.product.add_to_cart' | t | default: 'Add to Cart' }}
              {%- else -%}
                {{ 'products.product.sold_out' | t | default: 'Sold Out' }}
              {%- endif -%}
            </button>
          </div>
        </div>
      {%- else -%}
        <p style="padding: 16px; font-size: 0.875rem; opacity: 0.6;">No products tagged.</p>
      {%- endfor -%}
    </div>
  {%- endfor -%}

  {%- comment -%} Cards grid {%- endcomment -%}
  <div class="ugc-gallery">
    {%- if section.settings.heading != blank -%}
      <h2 class="ugc-gallery__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="ugc-gallery__grid" style="--columns: {{ section.settings.columns_desktop }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign video_src = ''
          if block.settings.video != blank
            assign first_mp4 = block.settings.video.sources | where: 'format', 'mp4' | first
            if first_mp4 != blank
              assign video_src = first_mp4.url
            else
              assign first_source = block.settings.video.sources | first
              if first_source != blank
                assign video_src = first_source.url
              endif
            endif
          endif
          assign card_sizes = '(min-width: 750px) calc(100vw / ' | append: section.settings.columns_desktop | append: '), 50vw'
          assign thumb = block.settings.thumbnail_image
          if thumb == blank and block.settings.video != blank
            assign thumb = block.settings.video.preview_image
          endif
        -%}
        <div
          class="ugc-card"
          data-block-id="{{ block.id }}"
          data-video-src="{{ video_src }}"
          style="--card-delay: {{ forloop.index0 | times: 0.09 }}s"
          on:click="/openModal"
          tabindex="0"
          role="button"
          aria-label="
            {%- if block.settings.handle != blank -%}
              Play video by {{ block.settings.handle | escape }}
            {%- else -%}
              View products
            {%- endif -%}
          "
          {{ block.shopify_attributes }}
        >
          <div class="ugc-card__media">
            {%- if thumb != blank -%}
              {{
                thumb
                | image_url: width: 800
                | image_tag:
                  class: 'ugc-card__thumbnail',
                  loading: 'lazy',
                  widths: '400,600,800',
                  sizes: card_sizes
              }}
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'ugc-card__thumbnail placeholder' }}
            {%- endif -%}

            <div class="ugc-card__overlay"></div>

            <div class="ugc-card__play-btn" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 3.5L14.5 9L6 14.5V3.5Z" fill="currentColor"/>
              </svg>
            </div>

            {%- if block.settings.handle != blank -%}
              <span class="ugc-card__handle">{{ block.settings.handle }}</span>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>

  {%- comment -%} Shared modal — single instance, populated by JS per card click {%- endcomment -%}
  <dialog
    ref="dialog"
    class="dialog-modal ugc-modal"
    aria-modal="true"
    aria-label="{{ 'sections.shoppable_video_gallery.modal_label' | t | default: 'Shop the look' }}"
  >
    <button
      class="ugc-modal__close"
      on:click="/closeDialog"
      aria-label="{{ 'accessibility.close' | t | default: 'Close' }}"
    >
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
      </svg>
    </button>

    <div class="ugc-modal__inner">
      <div class="ugc-modal__video-pane">
        <video
          ref="modalVideo"
          class="ugc-modal__video"
          loop
          muted
          playsinline
        ></video>
      </div>

      <div class="ugc-modal__product-pane">
        <h2 class="ugc-modal__heading">{{ 'sections.shoppable_video_gallery.shop_the_look' | t | default: 'Shop the look' }}</h2>
        <div ref="productsContainer" class="ugc-modal__products"></div>
      </div>
    </div>
  </dialog>

</shoppable-video-gallery-component>

<script src="{{ 'shoppable-video-gallery.js' | asset_url }}" type="module" fetchpriority="low"></script>

{% schema %}
{
  "name": "Shoppable Video Gallery",
  "tag": "section",
  "class": "section-shoppable-video-gallery",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As Seen On"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "ugc_video_item",
      "name": "UGC Video Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail_image",
          "label": "Thumbnail image",
          "info": "Portrait (3:4 ratio recommended). Falls back to video preview image if left blank."
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Creator handle",
          "placeholder": "@username"
        },
        {
          "type": "product_list",
          "id": "product_list",
          "label": "Tagged products",
          "limit": 6
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shoppable Video Gallery",
      "blocks": [
        { "type": "ugc_video_item" },
        { "type": "ugc_video_item" },
        { "type": "ugc_video_item" },
        { "type": "ugc_video_item" }
      ]
    }
  ]
}
{% endschema %}
