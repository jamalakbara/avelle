<style>

/* Zodiak - Serif / Headings */
@font-face {
  font-family: 'Zodiak';
  src: url("{{ 'Zodiak-Light.woff2' | asset_url }}") format("woff2");
  font-weight: 300;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Zodiak';
  src: url("{{ 'Zodiak-Regular.woff2' | asset_url }}") format("woff2");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Zodiak';
  src: url("{{ 'Zodiak-Regular.woff2' | asset_url }}") format("woff2");
  font-weight: 500;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Zodiak';
  src: url("{{ 'Zodiak-Bold.woff2' | asset_url }}") format("woff2");
  font-weight: 600;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Zodiak';
  src: url("{{ 'Zodiak-Bold.woff2' | asset_url }}") format("woff2");
  font-weight: 700;
  font-style: normal;
  font-display: swap;
}

/* Poppins - Sans-serif / Body */
@font-face {
  font-family: 'Poppins';
  src: url("{{ 'poppins-light.otf' | asset_url }}") format("opentype");
  font-weight: 300;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Poppins';
  src: url("{{ 'poppins-regular.otf' | asset_url }}") format("opentype");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Poppins';
  src: url("{{ 'poppins-medium.otf' | asset_url }}") format("opentype");
  font-weight: 500;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Poppins';
  src: url("{{ 'poppins-semibold.otf' | asset_url }}") format("opentype");
  font-weight: 600;
  font-style: normal;
  font-display: swap;
}

@font-face {
  font-family: 'Poppins';
  src: url("{{ 'poppins-bold.otf' | asset_url }}") format("opentype");
  font-weight: 700;
  font-style: normal;
  font-display: swap;
}

/* Override Theme Variables - Using html:root for higher specificity (0-2-0) than :root (0-1-0) */
html:root {
  /* Correct double-dash variables used by theme */
  --font-heading--family: 'Zodiak', serif !important;
  --font-body--family: 'Poppins', sans-serif !important;
  --font-subheading--family: 'Zodiak', serif !important;
  --font-accent--family: 'Zodiak', serif !important;

  /* Legacy single-dash (just in case) */
  --font-heading-family: 'Zodiak', serif !important;
  --font-body-family: 'Poppins', sans-serif !important;

  /* Adjust weights/styles */
  --font-heading--weight: 400 !important;
  --font-body--weight: 400 !important;
  --font-heading-weight: 400 !important;
  --font-body-weight: 400 !important;

  /* Fix blurry/jagged pill borders (sub-pixel rendering issue) */
  --variant-pills-border-width: 1px !important;
  --buttons-border-width: 1px !important;
  --inputs-border-width: 1px !important;
}

/* Fix jagged variant pill borders directly by overriding box-shadow and ::after elements */
.product-form__input input[type='radio'] + label,
variant-picker input[type='radio'] + label,
fieldset.product-form__input label,
.product-form__input label {
  border: 1px solid rgba(0,0,0,0.2) !important;
  box-shadow: none !important;
}

.product-form__input input[type='radio']:checked + label,
variant-picker input[type='radio']:checked + label {
  border-color: rgba(0,0,0,1) !important;
  box-shadow: none !important;
}

/* Dawn themes usually use ::after or ::before for the border/focus ring. We must hide them if they are causing anti-aliasing issues */
.product-form__input input[type='radio'] + label::after,
.product-form__input input[type='radio'] + label::before,
variant-picker input[type='radio'] + label::after,
variant-picker input[type='radio'] + label::before,
.product-form__input label::after,
.product-form__input label::before {
  display: none !important;
  content: none !important;
  box-shadow: none !important;
}

/* Direct overrides for common elements */
body,
h1,
h2,
h3,
h4,
h5,
h6,
.h1,
.h2,
.h3,
.h4,
.h5,
.h6 {
  font-family: var(--font-body--family);
}

h1,
h2,
h3,
h4,
h5,
h6,
.h1,
.h2,
.h3,
.h4,
.h5,
.h6 {
  font-family: var(--font-heading--family);
}

/* Animation Keyframes */
@keyframes fade-up-reveal {
  0% {
    opacity: 0;
    transform: translateY(20px);
  }

  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Product Details Typography & Animations */
.product-details .text-block h1 {
  font-family: 'Zodiak', serif !important;
  font-size: 2.5rem !important;
  /* Cinematic size, slightly reduced */
  font-weight: 400;
  line-height: 1.1;
  opacity: 0;
  text-align: left !important;
  /* Editorial Left Align */
  animation: fade-up-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* Accordion Titles - elegant serif */
.accordion summary,
.accordion__title,
.product-details .accordion summary {
  font-family: 'Zodiak', serif !important;
  font-weight: 400 !important;
  letter-spacing: 0.05em;
  text-transform: capitalize;
  font-size: 1.25rem;
}

/* Variant Labels - soften uppercase */
variant-picker legend,
.product-form__input .form__label,
.product-form__input legend {
  font-weight: 400 !important;
  letter-spacing: 0.1em;
  font-size: 0.8rem;
  opacity: 0.8;
}

.product-details product-price .price {
  font-family: var(--font-body--family) !important;
  font-size: 1.1rem !important;
  /* Clean modern size */
  font-weight: 400 !important;
  /* Balance with text */
  letter-spacing: 0.05em;
  /* Premium letter spacing for functional numbers */
  font-variant-numeric: tabular-nums;
  opacity: 0;
  text-align: left !important;
  display: block;
  /* Ensure it takes full width for alignment */
  animation: fade-up-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  animation-delay: 0.1s;
}

/* Editorial Layout Refinements */
.product-details .product-form__buttons,
.product-details .text-block {
  text-align: left !important;
  justify-content: flex-start !important;
  align-items: flex-start !important;
}

/* Ensure typography matches across all Buy buttons */
.shopify-payment-button__button,
.shopify-payment-button__button--unbranded {
  font-family: var(--font-body--family) !important;
  text-transform: uppercase !important;
  letter-spacing: 0.1em !important;
  font-size: 0.875rem !important;
  font-weight: 500 !important;
}

/* ==========================================================================
   AWWWARDS CAROUSEL STYLING
   ========================================================================== */

/* Spacing and Pagination Overlapping the Image */
.media-gallery--carousel {
  position: relative !important;
  padding-bottom: 0 !important;
}

.media-gallery--carousel slideshow-controls {
  margin-top: 0 !important;
  position: absolute !important;
  bottom: 7rem !important; /* Moved fully inside the image bounds */
  left: 50% !important;
  transform: translateX(-50%) !important;
  z-index: 15 !important;
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
  pointer-events: none; /* Let drag events pass through */
}

/* Pagination Counter Hidden (Cinematic Mode) */
.media-gallery--carousel .slideshow-controls__counter,
.media-gallery--carousel slideshow-controls {
  display: none !important;
}
.media-gallery--carousel .slider-button {
  background: transparent !important;
  border: none !important;
  box-shadow: none !important;
  color: var(--color-foreground) !important;
  opacity: 0.6;
  transition: opacity 0.3s ease, transform 0.3s ease;
  width: 44px;
  height: 44px;
}
.media-gallery--carousel .slider-button:hover {
  opacity: 1;
  transform: scale(1.1);
}
.media-gallery--carousel .slider-button .icon {
  width: 1.8rem; /* Make the arrow slightly larger/longer */
  height: auto;
}

/* Pagination Counter */
.media-gallery--carousel .slideshow-controls__counter {
  font-family: 'Zodiak', serif !important;
  font-size: 1.1rem !important;
  letter-spacing: 0.1em;
  color: var(--color-foreground) !important;
  opacity: 0.8;
  margin: 0 2rem; /* Give breathing room between arrows and counter */
}

/* Custom DRAG Cursor styling (Cinematic Exclusion Blend) */
.awwwards-drag-cursor {
  position: fixed;
  top: 0;
  left: 0;
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  color: #000;
  display: flex !important;
  align-items: center;
  justify-content: center;
  font-family: 'Zodiak', serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  z-index: 999999;
  pointer-events: none;
  opacity: 0;
  transform: translate(-50%, -50%) scale(0.5);
  transition: opacity 0.3s cubic-bezier(0.16, 1, 0.3, 1), transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  mix-blend-mode: exclusion;
  will-change: transform;
}

.awwwards-drag-cursor.is-active {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

.awwwards-drag-cursor.is-dragging {
  transform: translate(-50%, -50%) scale(0.8);
  background: rgba(255, 255, 255, 1);
}

/* Hide default cursor on the slider images */
.media-gallery--carousel {
  cursor: none !important;
}
.media-gallery--carousel * {
  cursor: none !important;
}
</style>